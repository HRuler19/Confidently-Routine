{
  "name": "confidently-routine",
  "version": "1.0.0",
  "description": "Confidently Routine - habit, task and notes tracker",
  "main": "main.js",
  "scripts": {
    "build:js": "rollup -c",
    "start": "electron .",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "rollup": "^4.62.2",
    "rollup-plugin-babel": "^4.4.0",
    "rollup-plugin-terser": "^7.0.2"
  },
  "build": {
    "appId": "com.millihasap.confidentlyroutine",
    "productName": "Confidently Routine",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "index.html",
      "assets/**/*",
      "views/**/*",
      "dist/**/*",
      "!assets/**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
